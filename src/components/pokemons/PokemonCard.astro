---
interface Props {
	name: string;
	url: string;
	isBig?: boolean;
}

const { name, url, isBig = false } = Astro.props;
const id = url.split("/").at(-2);

const imageUrl = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
---

<!-- class=`rounded-lg border flex flex-col justify-center items-center bg-slate-700 p-2 ${!isBig && "border"}` -->
<a
	class:list={[
		`rounded-lg flex flex-col justify-center items-center bg-slate-700 p-2`,
		{
			border: !isBig,
		},
	]}
	href={`/pokemons/${name}`}
>
	<img
		transition:name={`${name}-image`}
		class:list={[
			{
				"w-100 h-100": isBig,
				"w-16 h-16": !isBig,
			},
		]}
		src={imageUrl}
		alt={name}
	/>
	<span
		class:list={[
			"font-semibold capitalize",
			{
				"text-4xl text-blue-300": isBig,
			},
		]}
	>
		#{id}
		{name}
	</span>
</a>
